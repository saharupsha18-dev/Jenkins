pipeline {
  agent any
  tools {
    nodejs 'NodeJS'
   }
  stages {
    stage('Check') {
            steps {
                sh 'node -v'
                sh 'npm -v'
            }
        }
    stage("Checkout") {
      steps {
        checkout scm
        }
     }

    stage("Install"){
      steps {
        sh 'npm install'
       }
     }

    stage("Test"){
      steps {
        sh 'npm test'
        }
     }
   }
 }
     
