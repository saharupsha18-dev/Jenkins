pipeline {
    agent any

    stages {
        stage('Go Inside Folder and Check Files') {
            steps {
                sh '''
                    cd demo
                    pwd
                    ls -la
                '''
            }
        }

        stage('Build Docker Image') {
            steps {
                sh '''
                    cd demo
                    docker build -t my-jenkins-demo .
                '''
            }
        }

       stage('Run Docker container') {
           steps {
               sh 'docker run --name my-jenkins-cont my-jenkins-demo'
            }
        }
    }
}
