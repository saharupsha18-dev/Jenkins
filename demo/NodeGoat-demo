pipeline {
  agent any
  tools {
    node js 'NodeJS'
   }
  stages {
    
    stage("Checkout") {
      steps {
        checkout scm
        }
     }

    stage("Install"){
      steps {
        sh 'npm install'
       }
     }

    stage("Test"){
      steps {
        sh 'npm test'
        }
     }
   }
 }
     
